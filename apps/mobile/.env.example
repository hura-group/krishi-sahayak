# ─────────────────────────────────────────────────────────────────────────────
# KrishiSahayak — Mobile App Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Google Maps ──────────────────────────────────────────────────────────────
# Used for: Mandi Locator map (react-native-maps with PROVIDER_GOOGLE)
# How to get one:
#   1. Go to https://console.cloud.google.com
#   2. Create a project (or pick an existing one)
#   3. Enable these APIs:
#        - Maps SDK for Android
#        - Maps SDK for iOS
#        - Places API         (for location search)
#        - Directions API     (for Get Directions button)
#   4. Create an API key under APIs & Services → Credentials
#   5. Restrict it to your app's bundle ID / SHA-1 fingerprint (recommended)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ── Expo ─────────────────────────────────────────────────────────────────────
# Get this from: https://expo.dev → your project → settings
# Used for: sending push notifications via Expo's push service
EXPO_PUBLIC_PROJECT_ID=your-expo-project-id-here

# ── Sentry (optional — crash reporting) ─────────────────────────────────────
# Get this from: https://sentry.io → your project → Settings → SDK Setup
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
